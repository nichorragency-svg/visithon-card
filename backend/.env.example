# MongoDB Atlas — Connect → Drivers se POORI string copy karo.
# Host kabhi sirf "cluster0.mongodb.net" NAHI — hamesha "cluster0.ab12cd.mongodb.net" jaisa hota hai.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.YOUR_ID.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE_NAME=EventThon_Network

# JWT (use a long random string in production)
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# CORS — required when the React app and API are on different origins (admin, vCard images).
# Browser "Origin" is the PAGE (e.g. http://IP:80), NOT the API URL (http://IP:8000).
# If CORS_ALLOWED_ORIGINS is set but missing your site origin, the browser shows:
#   No 'Access-Control-Allow-Origin' header is present
#
# VPS example (Nginx serves React on :80, Uvicorn on :8000):
# CORS_ALLOWED_ORIGINS=http://159.65.138.9,http://localhost:3000
# Optional regex (matches list OR regex); escape dots for a literal IP:
# CORS_ALLOW_ORIGIN_REGEX=^https?://159\.65\.138\.9(:\d+)?$
# CORS_ALLOW_CREDENTIALS=true
#
# If both CORS_ALLOWED_ORIGINS and CORS_ALLOW_ORIGIN_REGEX are unset, the API still sends explicit
# allow_origins (VPS IP + common localhost ports) — see main.py _VPS_BROWSER_ORIGIN.

# Admin: POST /admin/provision-card-user (alias POST /admin/create-card-user) — Supabase Auth user with confirmed email.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role — server only, never expose to frontend or git

# Admin panel (separate from card JWT — set a unique secret)
ADMIN_JWT_SECRET=change-me-admin-only-secret
# Optional: required in POST /admin/register body as bootstrap_secret when at least one admin exists
# ADMIN_BOOTSTRAP_SECRET=long-random-secret-for-adding-admins
# ADMIN_JWT_EXPIRE_MINUTES=480
