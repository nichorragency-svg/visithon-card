# FastAPI backend (MongoDB + JWT on DigitalOcean VPS)
# REACT_APP_API_BASE_URL=http://159.65.138.9:8000
#
# Public React app URL for QR codes (port 80 — NOT :8000). Required if you open the admin/API on :8000.
# REACT_APP_PUBLIC_APP_URL=http://159.65.138.9
# (same meaning) REACT_APP_API_URL=http://159.65.138.9:8000
#
# Dev: omit to use http://127.0.0.1:8000 automatically with `npm start` only (not production build).

# Admin panel: hide “Create admin” unless you explicitly need it (avoids duplicate admins by mistake).
# REACT_APP_ADMIN_SHOW_REGISTER=true
