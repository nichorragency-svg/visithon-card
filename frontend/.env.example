# --- Visithon card app (required on Vercel) ---
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# --- Required for Admin Panel (`/admin/*`) — especially on Vercel production ---
# Without this in production builds, login shows "Something went wrong" (request never hits FastAPI).
# REACT_APP_API_BASE_URL=https://your-fastapi-host.com
# (same meaning) REACT_APP_API_URL=https://your-fastapi-host.com
#
# Dev: omit to use http://127.0.0.1:8000 automatically with `npm start` only (not production build).

# Admin panel: hide “Create admin” unless you explicitly need it (avoids duplicate admins by mistake).
# REACT_APP_ADMIN_SHOW_REGISTER=true
